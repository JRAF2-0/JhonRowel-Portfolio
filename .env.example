# n8n webhook URL for the chat widget.
# Get this from n8n: open your workflow → Webhook node → copy the
# **Production** URL (not Test URL). The widget will gracefully show
# a fallback message until this is set.
#
# Local: copy this file to `.env.local` and paste your URL below.
# Vercel: Project → Settings → Environment Variables.
VITE_CHAT_WEBHOOK_URL=
